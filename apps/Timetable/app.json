{
  "configVersion": "v3",

  "app": {
    "appId": 52756,
    "appName": "Timetable",
    "appType": "app",
    "package": "com.zepp.Timetable",
    "version": {
      "code": 1,
      "name": "1.0.1"
    },
    "icon": "image.png",
    "vender": "zepp",
    "description": "This is a timetable app for Zepp OS."
  },


  "resources": {
    "files": [
      "assets/timetable.json"
    ]
  },


  "permissions": [
    "data:os.device.info",
    "device:os.local_storage",
    "device:os.accelerometer",
    "device:os.gyroscope",
    "data:user.hd.sleep",
    "sensor",
    "device.storage",
    "device.vibrate"
  ],


  "runtime": {
    "apiVersion": {
      "compatible": "4.0",
      "target": "4.0",
      "minVersion": "4.0"
    }
  },


  "debug": false,


  "targets": {
    "gt": {

      "module": {

        "page": {

          "pages": [
            "page/gt/home/index.page"
          ]

        },


        "appSide": {
          "path": "app-side/index"
        }

      },


      "platforms": [
        {
          "st": "r"
        },
        {
          "st": "s"
        }
      ],


      "designWidth": 480

    }
  },


  "i18n": {
    "en-US": {
      "appName": "Timetable"
    },

    "zh-CN": {
      "appName": "时间表"
    }
  },


  "defaultLanguage": "en-US"
}